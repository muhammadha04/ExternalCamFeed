

f = find(respEsti.respAngles>180);
results = respEsti.respAngles;
results(f) = results(f)-360*ones(1,length(f));
f0 = find(results>90);
results(f0) = NaN;

angles = [2 358 ;4 356 ;8 352];

figure;
for i = 1:size(angles,1)
    f1 = find(angles(i,1));
    f2 = find(angles(i,2));
    
    subplot(3,i)
